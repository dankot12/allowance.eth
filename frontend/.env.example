# ─────────────────────────────────────────────────────────────
# Allowance.eth — Frontend Environment Variables
# Copy this file to .env.local and fill in the values
# ─────────────────────────────────────────────────────────────

# Anthropic API key — for the /api/translate-policy route
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# PolicyGuard.sol deployment address (Sepolia)
# Run: forge script script/DeployPolicyGuard.s.sol --broadcast
# then copy the printed address here
NEXT_PUBLIC_POLICY_GUARD_ADDRESS=0x0000000000000000000000000000000000000000

# ENS Public Resolver on Sepolia (default is correct, only change if using a custom resolver)
NEXT_PUBLIC_ENS_RESOLVER=0x005fEc2fC3741D1ae1e487BB550A4b0F54263645

# Sepolia RPC URL — use Alchemy/Infura for reliability, or the public endpoint
NEXT_PUBLIC_RPC_URL=https://rpc.sepolia.org

# Dynamic SDK Environment ID (for wallet connect)
# Get one at https://app.dynamic.xyz
NEXT_PUBLIC_DYNAMIC_ENV_ID=your-dynamic-env-id
