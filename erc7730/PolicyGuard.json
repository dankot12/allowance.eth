{
  "$schema": "https://schemas.ledger.com/erc7730/v1/schema.json",

  "context": {
    "contract": {
      "abi": [
        {
          "name": "updatePolicy",
          "type": "function",
          "stateMutability": "nonpayable",
          "inputs": [
            { "name": "namehash",   "type": "bytes32" },
            { "name": "policyHash", "type": "bytes32" }
          ],
          "outputs": []
        },
        {
          "name": "check",
          "type": "function",
          "stateMutability": "nonpayable",
          "inputs": [
            { "name": "namehash_",  "type": "bytes32" },
            { "name": "target",     "type": "address" },
            { "name": "value",      "type": "uint256" },
            { "name": "data",       "type": "bytes" },
            {
              "name": "policy",
              "type": "tuple",
              "components": [
                {
                  "name": "dailyCap",
                  "type": "tuple",
                  "components": [
                    { "name": "amount",  "type": "uint256" },
                    { "name": "enabled", "type": "bool" }
                  ]
                },
                {
                  "name": "approvalThreshold",
                  "type": "tuple",
                  "components": [
                    { "name": "amount",  "type": "uint256" },
                    { "name": "enabled", "type": "bool" }
                  ]
                },
                {
                  "name": "perCounterpartyCap",
                  "type": "tuple",
                  "components": [
                    { "name": "amount",  "type": "uint256" },
                    { "name": "enabled", "type": "bool" }
                  ]
                },
                {
                  "name": "timeWindow",
                  "type": "tuple",
                  "components": [
                    { "name": "start",   "type": "uint32" },
                    { "name": "end",     "type": "uint32" },
                    { "name": "enabled", "type": "bool" }
                  ]
                },
                { "name": "allowlist",        "type": "address[]" },
                { "name": "allowlistEnabled", "type": "bool" }
              ]
            },
            { "name": "policyJson", "type": "string" }
          ],
          "outputs": [{ "name": "", "type": "bool" }]
        },
        {
          "name": "transferPolicyOwnership",
          "type": "function",
          "stateMutability": "nonpayable",
          "inputs": [
            { "name": "namehash_", "type": "bytes32" },
            { "name": "newOwner",  "type": "address" }
          ],
          "outputs": []
        }
      ],
      "deployments": [
        {
          "chainId": 11155111,
          "address": "0x95028D3bFb24c168E55bEead6FFd3AeA2851c4dA"
        }
      ]
    }
  },

  "metadata": {
    "owner": "Allowance.eth",
    "info": {
      "url": "https://allowance.eth",
      "legalName": "Allowance.eth — Agent Spending Policies",
      "lastUpdate": "2024-01-01T00:00:00Z"
    },
    "token": null,
    "constants": {
      "sepoliaExplorer": "https://sepolia.etherscan.io"
    },
    "enumerations": {}
  },

  "display": {
    "definitions": {
      "wei_to_eth": {
        "type": "tokenAmount",
        "token": "0xEeeeeEeeeEeEeeEeEeEeeEEEeeeeEeeeeeeeEEeE",
        "message": "ETH"
      }
    },

    "formats": {

      "updatePolicy(bytes32,bytes32)": {
        "intent": "Publish Agent Spending Policy",
        "fields": [
          {
            "path": "namehash",
            "label": "Agent ENS Namehash",
            "format": "raw"
          },
          {
            "path": "policyHash",
            "label": "Policy Hash (keccak256 of JSON)",
            "format": "raw"
          }
        ],
        "screens": {
          "default": [
            {
              "type": "propertyPage",
              "label": "POLICY UPDATE",
              "fields": ["namehash", "policyHash"]
            }
          ]
        },
        "required": ["namehash", "policyHash"]
      },

      "check(bytes32,address,uint256,bytes,(((uint256,bool),(uint256,bool),(uint256,bool),(uint32,uint32,bool),address[],bool)),string)": {
        "intent": "Agent Transaction — Policy Check",
        "fields": [
          {
            "path": "target",
            "label": "Transaction Target",
            "format": "addressName",
            "params": {
              "sources": ["local", "ens"]
            }
          },
          {
            "path": "value",
            "label": "ETH Value",
            "format": "tokenAmount",
            "params": {
              "token": "native",
              "message": "ETH"
            }
          },
          {
            "path": "policy.dailyCap.amount",
            "label": "Daily Cap",
            "format": "tokenAmount",
            "params": {
              "token": "native",
              "message": "wei"
            }
          },
          {
            "path": "policy.approvalThreshold.amount",
            "label": "Approval Threshold",
            "format": "tokenAmount",
            "params": {
              "token": "native",
              "message": "wei"
            }
          },
          {
            "path": "policy.allowlistEnabled",
            "label": "Allowlist Active",
            "format": "raw"
          },
          {
            "path": "policy.timeWindow.start",
            "label": "Window Start (seconds UTC)",
            "format": "raw"
          },
          {
            "path": "policy.timeWindow.end",
            "label": "Window End (seconds UTC)",
            "format": "raw"
          }
        ],
        "screens": {
          "default": [
            {
              "type": "propertyPage",
              "label": "AGENT REQUEST",
              "fields": ["target", "value"]
            },
            {
              "type": "propertyPage",
              "label": "ACTIVE POLICY",
              "fields": [
                "policy.dailyCap.amount",
                "policy.approvalThreshold.amount",
                "policy.allowlistEnabled"
              ]
            }
          ]
        },
        "required": ["target", "value"]
      },

      "transferPolicyOwnership(bytes32,address)": {
        "intent": "Transfer Policy Ownership",
        "fields": [
          {
            "path": "namehash_",
            "label": "Agent ENS Namehash",
            "format": "raw"
          },
          {
            "path": "newOwner",
            "label": "New Owner Address",
            "format": "addressName",
            "params": {
              "sources": ["local", "ens"]
            }
          }
        ],
        "screens": {
          "default": [
            {
              "type": "propertyPage",
              "label": "TRANSFER OWNERSHIP",
              "fields": ["namehash_", "newOwner"]
            }
          ]
        },
        "required": ["namehash_", "newOwner"]
      }

    }
  }
}
