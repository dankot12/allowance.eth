      "setHumanApprover(bytes32,address)": {
        "intent": "Authorize Ledger Device for Approvals",
        "fields": [
          {
            "path": "namehash_",
            "label": "ENS Name",
            "format": "raw"
          },
          {
            "path": "approver",
            "label": "Ledger Approver Address",
            "format": "address"
          }
        ],
        "screens": {
          "ledger": [
            {
              "title": "Set Ledger Approver",
              "fields": ["namehash_", "approver"]
            }
          ]
        }
