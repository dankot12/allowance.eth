  "display": {
    "formats": {

      "updatePolicy(bytes32,bytes32)": {
        "intent": "Register Spending Policy",
        "fields": [
          {
            "path": "namehash_",
            "label": "ENS Name Hash",
            "format": "raw"
          },
          {
            "path": "policyHash",
            "label": "Policy Hash (keccak256 of JSON)",
            "format": "raw"
          }
        ],
        "screens": {
          "ledger": [
            {
              "title": "Register Policy",
              "fields": ["namehash_", "policyHash"]
            }
          ]
        }
      },

      "check(bytes32,address,uint256,bytes,(((uint256,bool),(uint256,bool),(uint256,bool),(uint32,uint32,bool),address[],bool)),string)": {
        "intent": "Authorize Agent Transaction",
        "fields": [
          {
            "path": "target",
            "label": "Destination",
            "format": "addressName",
            "params": { "enumPath": "$.metadata.enums.KnownContract" }
          },
          {
            "path": "value",
            "label": "Amount (USDC)",
            "format": "tokenAmount",
            "params": { "tokenPath": "USDC", "decimals": 18 }
          },
          {
            "path": "policy.dailyCap.amount",
            "label": "Daily Cap",
            "format": "tokenAmount",
            "params": { "tokenPath": "USDC", "decimals": 18 }
          },
          {
            "path": "policy.approvalThreshold.amount",
            "label": "Auto-Approve Below",
            "format": "tokenAmount",
            "params": { "tokenPath": "USDC", "decimals": 18 }
          },
          {
            "path": "policy.timeWindow.start",
            "label": "Window Opens (UTC seconds)",
            "format": "raw"
          },
          {
            "path": "policy.timeWindow.end",
            "label": "Window Closes (UTC seconds)",
            "format": "raw"
          }
        ],
        "screens": {
          "ledger": [
            {
              "title": "Agent Tx Check",
              "fields": ["target", "value"]
            },
            {
              "title": "Spending Rules",
              "fields": ["policy.dailyCap.amount", "policy.approvalThreshold.amount"]
            },
            {
              "title": "Time Window",
              "fields": ["policy.timeWindow.start", "policy.timeWindow.end"]
            }
          ]
        }
      },

      "checkWithHumanApproval(bytes32,address,uint256,bytes,(((uint256,bool),(uint256,bool),(uint256,bool),(uint32,uint32,bool),address[],bool)),string,bytes)": {
        "intent": "Approve Agent Transaction (Human Override)",
        "fields": [
          {
            "path": "target",
            "label": "Destination",
            "format": "addressName",
            "params": { "enumPath": "$.metadata.enums.KnownContract" }
          },
          {
            "path": "value",
            "label": "Amount (USDC)",
            "format": "tokenAmount",
            "params": { "tokenPath": "USDC", "decimals": 18 }
          },
          {
            "path": "policy.approvalThreshold.amount",
            "label": "Threshold Exceeded Above",
            "format": "tokenAmount",
            "params": { "tokenPath": "USDC", "decimals": 18 }
          },
          {
            "path": "policy.dailyCap.amount",
            "label": "Daily Cap",
            "format": "tokenAmount",
            "params": { "tokenPath": "USDC", "decimals": 18 }
          }
        ],
        "screens": {
          "ledger": [
            {
              "title": "Human Approval",
              "fields": ["target", "value"]
            },
            {
              "title": "Policy Limits",
              "fields": ["policy.approvalThreshold.amount", "policy.dailyCap.amount"]
            }
          ]
        }
      },

      "transferPolicyOwnership(bytes32,address)": {
        "intent": "Transfer Policy Control",
        "fields": [
          {
            "path": "namehash_",
            "label": "ENS Name",
            "format": "raw"
          },
          {
            "path": "newOwner",
            "label": "New Owner Address",
            "format": "address"
          }
        ],
        "screens": {
          "ledger": [
            {
              "title": "Transfer Policy",
              "fields": ["namehash_", "newOwner"]
            }
          ]
        }
