  "metadata": {
    "owner": "Allowance.eth",
    "info": {
      "url": "https://allowance.eth",
      "legalName": "Allowance.eth Protocol",
      "lastUpdate": "2026-06-13"
    },
    "enums": {
      "KnownContract": {
        "0x68b3465833fb72A70ecDF485E0e4C7bD8665Fc45": "Uniswap V3 SwapRouter02",
